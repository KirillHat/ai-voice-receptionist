# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VOICE_FROM=+13105550123
TWILIO_VALIDATE_SIGNATURE=true
DEBUG_SKIP_TWILIO_SIGNATURE=false

# Voice settings
TWILIO_SAY_VOICE=woman
TWILIO_SAY_LANGUAGE=en-US
GATHER_TIMEOUT_SECONDS=4
GATHER_SPEECH_TIMEOUT=auto
VOICE_MODE=conversationrelay
CONVERSATIONRELAY_PRIMARY_LANGUAGE=en-US
CONVERSATIONRELAY_TTS_PROVIDER=ElevenLabs
CONVERSATIONRELAY_STT_PROVIDER=Deepgram
CONVERSATIONRELAY_TTS_VOICE=Rachel
CONVERSATIONRELAY_VOICE_EN=Rachel
CONVERSATIONRELAY_VOICE_ES=Rachel
CONVERSATIONRELAY_VOICE_RU=Rachel
LLM_STREAMING_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
VOICE_SOFT_PAUSE_MIN_MS=220
VOICE_SOFT_PAUSE_MAX_MS=720
VOICE_FAST_UTTERANCE_WORDS=7
VOICE_LONG_UTTERANCE_WORDS=24
VOICE_HOLDING_PHRASE_DELAY_FAST_MS=750
VOICE_HOLDING_PHRASE_DELAY_SLOW_MS=1200
VOICE_INTERRUPT_ACK_WINDOW_SEC=12
VOICE_DISFLUENCY_RATE=0.12

# Integrations
SLACK_WEBHOOK_URL=
CRM_WEBHOOK_URL=
CRM_AUTH_BEARER=
ENABLE_SEVENROOMS=false
SEVENROOMS_API_BASE_URL=
SEVENROOMS_API_KEY=
SEVENROOMS_VENUE_ID=

# Recording
RECORD_CALLS=true
RECORDING_CHANNELS=dual
RECORDING_TRACK=both
RECORDING_TRIM=trim-silence
RECORDING_STATUS_CALLBACK_PATH=/webhooks/voice/recording-status

# App
